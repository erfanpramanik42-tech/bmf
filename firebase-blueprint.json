{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (admin or member)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "isSuperAdmin": { "type": "boolean" },
        "photo": { "type": "string" },
        "address": { "type": "string" },
        "join_date": { "type": "string" },
        "birthday": { "type": "string" },
        "pin_hash": { "type": "string" }
      },
      "required": ["id", "name", "phone", "role", "pin_hash"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Monthly deposit record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "member_id": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "fine": { "type": "boolean" }
      },
      "required": ["id", "month", "amount", "date", "fine"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loan record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "member_id": { "type": "string" },
        "amount": { "type": "number" },
        "interest": { "type": "number" },
        "installments": { "type": "integer" },
        "date": { "type": "string" },
        "purpose": { "type": "string" },
        "total_interest": { "type": "number" },
        "total_payable": { "type": "number" },
        "monthly_installment": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["id", "member_id", "amount", "interest", "installments", "date", "total_interest", "total_payable", "monthly_installment", "status"]
    },
    "Installment": {
      "title": "Installment",
      "description": "Loan installment payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "member_id": { "type": "string" },
        "loan_id": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["id", "member_id", "loan_id", "amount", "date"]
    },
    "Request": {
      "title": "Request",
      "description": "Member request for deposit, loan or installment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "loan", "installment"] },
        "member_id": { "type": "string" },
        "data": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "created_at": { "type": "string" },
        "approved_at": { "type": "string" },
        "approved_by": { "type": "string" }
      },
      "required": ["id", "type", "member_id", "data", "status", "created_at"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Fund investment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "expected_return": { "type": "number" },
        "profit": { "type": "number" },
        "invest_date": { "type": "string" },
        "maturity_date": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "received"] },
        "received_amount": { "type": "number" },
        "received_date": { "type": "string" }
      },
      "required": ["id", "title", "amount", "expected_return", "profit", "invest_date", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Fund expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["id", "title", "amount", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "target": { "type": "string" },
        "sent_at": { "type": "string" },
        "sent_by": { "type": "string" },
        "read_by": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "body", "target", "sent_at", "sent_by", "read_by"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "monthly_deposit": { "type": "number" },
        "interest_rate": { "type": "number" },
        "excel_link": { "type": "string" },
        "super_admin_phone": { "type": "string" },
        "super_admin_pin_hash": { "type": "string" }
      },
      "required": ["id", "monthly_deposit", "interest_rate", "super_admin_pin_hash"]
    },
    "Terms": {
      "title": "Terms",
      "description": "Foundation terms and conditions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "membership": { "type": "array", "items": { "type": "string" } },
        "deposit": { "type": "array", "items": { "type": "string" } },
        "loan": { "type": "array", "items": { "type": "string" } },
        "governance": { "type": "array", "items": { "type": "string" } },
        "special": { "type": "string" },
        "updated_at": { "type": "string" },
        "updated_by": { "type": "string" }
      },
      "required": ["id"]
    },
    "DeveloperInfo": {
      "title": "Developer Info",
      "description": "Information about the application developer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "facebook": { "type": "string" },
        "photo": { "type": "string" },
        "bio": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Fund official / Person in charge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "photo": { "type": "string" },
        "bkash": { "type": "string" },
        "nagad": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "name", "position", "phone"]
    },
    "Document": {
      "title": "Document",
      "description": "Foundation document or file link",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "image", "link", "other"] },
        "created_at": { "type": "string" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "title", "url", "type", "created_at"]
    }
  },
  "firestore": {
    "developer": {
      "schema": { "$ref": "DeveloperInfo" },
      "description": "Information about the developer"
    },
    "admins": { "schema": "User", "description": "Admin users" },
    "members": { "schema": "User", "description": "Foundation members" },
    "pending_regs": { "schema": "User", "description": "Pending registrations" },
    "deposits": { "schema": "Deposit", "description": "Deposit records" },
    "loans": { "schema": "Loan", "description": "Loan records" },
    "installments": { "schema": "Installment", "description": "Installment payments" },
    "requests": { "schema": "Request", "description": "Member requests" },
    "investments": { "schema": "Investment", "description": "Fund investments" },
    "expenses": { "schema": "Expense", "description": "Fund expenses" },
    "notifications": { "schema": "Notification", "description": "System notifications" },
    "settings": { "schema": "AppSettings", "description": "App settings" },
    "terms": { "schema": "Terms", "description": "Foundation terms" },
    "developer": { "schema": "object", "description": "Developer info" },
    "contacts": { "schema": "Contact", "description": "Contact persons / Officials" },
    "cash_entries": { "schema": "object", "description": "Cash fund entries" },
    "documents": { "schema": "Document", "description": "Foundation documents" }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        // Super Admin by Email
        (request.auth.token.email == "sujonali9091@gmail.com" && request.auth.token.email_verified == true) ||
        // Admin by linked Firebase UID (if we implement linking)
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || exists(/databases/$(database)/documents/members/$(userId)));
    }

    function isDocOwner() {
      return isAuthenticated() && (request.auth.uid == resource.data.member_id || resource.data.member_id == 'SUPER');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && (resource.data.firebase_uid == request.auth.uid || memberId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /pending_regs/{regId} {
      allow read: if isAuthenticated(); // Allow check during login
      allow create: if true; // Public registration
      allow delete: if isAdmin();
    }

    match /deposits/{depId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /loans/{loanId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /installments/{instId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /requests/{reqId} {
      allow read: if isAuthenticated(); // Simplified for now to avoid UID mismatch
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /investments/{invId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /expenses/{expId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated(); // For marking as read
      allow delete: if isAdmin();
    }

    match /terms/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /developer/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cash_entries/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
